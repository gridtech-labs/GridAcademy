<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@ViewData["Title"] — GridAcademy</title>

    <!-- Bootstrap 5.3.3 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHgthW77++lXyqiaW0bNMSv0it6gxi4O"
          crossorigin="anonymous" />

    <!-- KaTeX (for math rendering) -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
          integrity="sha384-wcIxkf4k558AjM3Yz3BBFQUbk/zgIYC2R0QpeeYb+TwlBVMrlgLqwRjRtGZiK7ww"
          crossorigin="anonymous" />

    <!-- Student Portal CSS -->
    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ── Top Navbar ─────────────────────────────────────────────── -->
    <nav class="student-navbar">

        @if (ViewData["ExamMode"] is true)
        {
            <!-- Exam mode: restricted navbar -->
            <span class="nav-brand" title="GridAcademy">
                <i class="bi bi-mortarboard-fill"></i>
                <span>GridAcademy</span>
            </span>

            <span class="nav-test-title" title="@ViewData["ExamTitle"]">
                @ViewData["ExamTitle"]
            </span>

            <!-- Countdown Timer (populated by exam JS) -->
            <div id="examTimer" class="exam-timer timer-safe" aria-live="polite" aria-label="Time remaining">
                --:--:--
            </div>

            <!-- Submit button — direct onclick, works in fullscreen and any JS state -->
            <button type="button"
                    id="btnSubmitExam"
                    class="btn-submit-exam"
                    onclick="var m=document.getElementById('submitConfirmModal'); if(m) bootstrap.Modal.getOrCreateInstance(m).show();">
                <i class="bi bi-check2-circle me-1"></i> Submit Test
            </button>
        }
        else
        {
            <!-- Normal mode: full navbar -->
            <a class="nav-brand" href="/Student/Dashboard">
                <i class="bi bi-mortarboard-fill"></i>
                <span>GridAcademy</span>
            </a>

            <div class="nav-spacer"></div>

            <a class="nav-link" href="/Student/Dashboard">
                <i class="bi bi-house-door me-1"></i> Dashboard
            </a>

            <span class="nav-username">
                <i class="bi bi-person-circle"></i>
                @User.Identity?.Name
            </span>

            <form method="post" action="/Account/Logout" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        }

    </nav>
    <!-- /Top Navbar -->

    <!-- ── Main Content ────────────────────────────────────────────── -->
    <main class="student-main">
        @RenderBody()
    </main>
    <!-- /Main Content -->

    <!-- ── Scripts ─────────────────────────────────────────────────── -->

    <!-- Bootstrap 5.3.3 JS — local copy (no CDN dependency) -->
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script>
        // Fallback: if local file failed to define window.bootstrap, load from CDN
        if (!window.bootstrap) {
            document.write('<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"><\/script>');
        }
    </script>

    <!-- KaTeX JS (auto-render) -->
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"
            integrity="sha384-hIoBPJpTUs74ddyc4bFZSM1TVlQDA60VBbJS0oA934VSz82sBx1X7kSx2ATBDIyd"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/contrib/auto-render.min.js"
            integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk"
            crossorigin="anonymous"></script>
    <script>
        // Auto-render KaTeX on page load
        document.addEventListener("DOMContentLoaded", function () {
            renderMathInElement(document.body, {
                delimiters: [
                    { left: "$$",  right: "$$",  display: true  },
                    { left: "$",   right: "$",   display: false },
                    { left: "\\(", right: "\\)", display: false },
                    { left: "\\[", right: "\\]", display: true  }
                ]
            });
        });
    </script>

    @if (ViewData["ExamMode"] is true)
    {
        <script>
            // Exam mode: disable right-click context menu
            document.addEventListener('contextmenu', function (e) {
                e.preventDefault();
            });

            // Exam mode: disable text selection via keyboard shortcuts
            document.addEventListener('keydown', function (e) {
                // Block Ctrl+C, Ctrl+A, Ctrl+V, Ctrl+X, F12, Ctrl+Shift+I
                if ((e.ctrlKey && ['c', 'a', 'v', 'x', 'u'].includes(e.key.toLowerCase())) ||
                    e.key === 'F12' ||
                    (e.ctrlKey && e.shiftKey && ['i', 'j', 'c'].includes(e.key.toLowerCase()))) {
                    e.preventDefault();
                }
            });
        </script>
    }

    @RenderSection("Scripts", required: false)

</body>
</html>
