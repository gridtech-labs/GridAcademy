@page
@model ProfileModel
@{
    ViewData["Title"] = "Provider Profile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-person-gear text-success me-2"></i>Provider Profile
    </h4>
    @if (Model.Provider is not null)
    {
        var statusBadge = Model.Provider.Status switch
        {
            "Verified"  => "success",
            "Suspended" => "danger",
            _           => "warning text-dark"
        };
        <span class="badge bg-@statusBadge fs-6">
            <i class="bi bi-shield-check me-1"></i>@Model.Provider.Status
        </span>
    }
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Form.InstituteName" class="form-label fw-medium"></label>
                        <input asp-for="Form.InstituteName" class="form-control" placeholder="Enter institute or organization name" />
                        <span asp-validation-for="Form.InstituteName" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Form.City" class="form-label fw-medium">City</label>
                            <input asp-for="Form.City" class="form-control" placeholder="City" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Form.State" class="form-label fw-medium">State</label>
                            <input asp-for="Form.State" class="form-control" placeholder="State" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Form.Bio" class="form-label fw-medium">Bio</label>
                        <textarea asp-for="Form.Bio" class="form-control" rows="4"
                                  placeholder="Brief description about your institute..."></textarea>
                        <div class="form-text">Max 500 characters.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Form.LogoUrl" class="form-label fw-medium"></label>
                        <input asp-for="Form.LogoUrl" class="form-control" placeholder="https://example.com/logo.png" />
                        <div class="form-text">Enter a publicly accessible URL for your institute logo.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-floppy me-2"></i>Save Changes
                        </button>
                        <a asp-page="/Provider/Dashboard" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-info-circle me-2 text-success"></i>Account Status
            </div>
            <div class="card-body">
                @if (Model.Provider is not null)
                {
                    var statusBadge = Model.Provider.Status switch
                    {
                        "Verified"  => "success",
                        "Suspended" => "danger",
                        _           => "warning text-dark"
                    };
                    <div class="mb-2">
                        <span class="text-muted small">Status</span><br />
                        <span class="badge bg-@statusBadge">@Model.Provider.Status</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-muted small">Member Since</span><br />
                        <span>@Model.Provider.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div>
                        <span class="text-muted small">Terms Agreed</span><br />
                        @if (Model.Provider.AgreedToTerms)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>
                        }
                        else
                        {
                            <span class="text-warning"><i class="bi bi-x-circle-fill me-1"></i>No</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="alert alert-info border-0 shadow-sm">
            <i class="bi bi-lightbulb me-2"></i>
            <strong>Note:</strong> Profile updates do not require admin re-approval.
            Your series review status is independent of profile changes.
        </div>

        @if (Model.Provider?.LogoUrl is not null)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-bottom fw-semibold small">Logo Preview</div>
                <div class="card-body text-center">
                    <img src="@Model.Provider.LogoUrl" alt="Logo" class="img-thumbnail" style="max-height:120px;" />
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
