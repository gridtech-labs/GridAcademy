@page
@model DashboardModel
@{
    ViewData["Title"] = "Provider Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-speedometer2 text-success me-2"></i>Provider Dashboard
    </h4>
    @if (Model.Profile is not null)
    {
        <span class="text-muted small">Welcome, <strong>@Model.Profile.InstituteName</strong></span>
    }
</div>

@if (Model.StatusWarning is not null)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 flex-shrink-0"></i>
        <div>@Model.StatusWarning</div>
    </div>
}

@if (Model.Stats is null)
{
    <div class="alert alert-info">Loading dashboard data...</div>
}
else
{
    <!-- Series Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-collection-play fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@Model.Stats.TotalSeries</div>
                        <div class="text-muted small">Total Series</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-check-circle fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@Model.Stats.PublishedSeries</div>
                        <div class="text-muted small">Published</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-clock fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@Model.Stats.PendingReviewSeries</div>
                        <div class="text-muted small">In Review</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-pencil-square fs-4 text-secondary"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@Model.Stats.DraftSeries</div>
                        <div class="text-muted small">Draft</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-currency-rupee fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">&#8377;@Model.Stats.TotalRevenue.ToString("N2")</div>
                        <div class="text-muted small">Total Revenue</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-hourglass-split fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">&#8377;@Model.Stats.PendingPayout.ToString("N2")</div>
                        <div class="text-muted small">Pending Payout</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-bag-check fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="fs-4 fw-bold">@Model.Stats.TotalSales</div>
                        <div class="text-muted small">Total Sales</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Performing Series -->
    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-bottom fw-semibold">
                    <i class="bi bi-trophy text-warning me-2"></i>Top Performing Series
                </div>
                <div class="card-body p-0">
                    @if (!Model.Stats.TopSeries.Any())
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="bi bi-collection-play fs-2 d-block mb-2 opacity-50"></i>
                            No series yet. <a asp-page="/Provider/Series/Create">Create your first test series!</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Title</th>
                                        <th>Status</th>
                                        <th class="text-center">Purchases</th>
                                        <th class="text-center">Avg Rating</th>
                                        <th class="text-end">Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.Stats.TopSeries)
                                    {
                                        <tr>
                                            <td class="fw-medium">@s.Title</td>
                                            <td>
                                                @{
                                                    var statusBadge = s.Status switch
                                                    {
                                                        "Published"     => "success",
                                                        "PendingReview" => "warning text-dark",
                                                        "Rejected"      => "danger",
                                                        _               => "secondary"
                                                    };
                                                }
                                                <span class="badge bg-@statusBadge">@s.Status</span>
                                            </td>
                                            <td class="text-center">@s.PurchaseCount</td>
                                            <td class="text-center">
                                                <i class="bi bi-star-fill text-warning small"></i>
                                                @s.AvgRating.ToString("N1")
                                            </td>
                                            <td class="text-end">&#8377;@s.Revenue.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-bottom fw-semibold">
                    <i class="bi bi-lightning-charge text-success me-2"></i>Quick Actions
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-page="/Provider/Series/Create" class="btn btn-success">
                        <i class="bi bi-plus-circle me-2"></i>Create New Series
                    </a>
                    <a asp-page="/Provider/Series/Index" class="btn btn-outline-primary">
                        <i class="bi bi-collection-play me-2"></i>My Series
                    </a>
                    <a asp-page="/Provider/Tests/Create" class="btn btn-outline-secondary">
                        <i class="bi bi-journal-plus me-2"></i>Create Test
                    </a>
                    <a asp-page="/Provider/Commissions/Index" class="btn btn-outline-warning">
                        <i class="bi bi-cash-coin me-2"></i>View Commissions
                    </a>
                    <a asp-page="/Provider/Profile" class="btn btn-outline-secondary">
                        <i class="bi bi-person-gear me-2"></i>Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
}
