@page
@model GridAcademy.Pages.Provider.Commissions.IndexModel
@using GridAcademy.Data.Entities.Marketplace
@{
    ViewData["Title"] = "Commissions & Revenue";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-cash-coin text-success me-2"></i>Commissions &amp; Revenue
    </h4>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-currency-rupee fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">&#8377;@Model.TotalEarned.ToString("N2")</div>
                    <div class="text-muted small">Total Earned</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-hourglass-split fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">&#8377;@Model.PendingPayout.ToString("N2")</div>
                    <div class="text-muted small">Pending Payout</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-check2-circle fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">&#8377;@Model.ProcessedPayout.ToString("N2")</div>
                    <div class="text-muted small">Processed</div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Commissions.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-cash-coin fs-1 text-muted opacity-50 d-block mb-3"></i>
            <h5 class="text-muted">No commissions yet</h5>
            <p class="text-muted mb-3">Publish a series to start earning!</p>
            <a asp-page="/Provider/Series/Create" class="btn btn-success">
                <i class="bi bi-plus-circle me-2"></i>Create a Series
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Booking Ref</th>
                        <th>Series</th>
                        <th class="text-end">Gross</th>
                        <th class="text-center">Platform %</th>
                        <th class="text-end">Platform Amt</th>
                        <th class="text-center">Your %</th>
                        <th class="text-end">Your Earnings</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Commissions)
                    {
                        <tr>
                            <td>
                                <code class="small">@c.BookingRef</code>
                            </td>
                            <td class="fw-medium small">@c.SeriesTitle</td>
                            <td class="text-end">&#8377;@c.GrossAmount.ToString("N2")</td>
                            <td class="text-center text-muted small">@c.PlatformPct%</td>
                            <td class="text-end text-muted small">&#8377;@c.PlatformAmount.ToString("N2")</td>
                            <td class="text-center text-muted small">@c.ProviderPct%</td>
                            <td class="text-end fw-semibold text-success">&#8377;@c.ProviderAmount.ToString("N2")</td>
                            <td>
                                @{
                                    var statusBadge = c.Status == CommissionStatus.Processed ? "success" : "warning text-dark";
                                }
                                <span class="badge bg-@statusBadge">@c.Status</span>
                            </td>
                            <td class="text-muted small">@c.CreatedAt.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="alert alert-light border mt-3 small">
        <i class="bi bi-info-circle me-2 text-primary"></i>
        <strong>Commission Split:</strong> Platform retains 30% and you earn 70% of the gross sale amount (subject to applicable GST).
        Payouts are processed by the admin team on a monthly basis.
    </div>
}
