@page
@model GridAcademy.Pages.Provider.Tests.CreateModel
@{
    ViewData["Title"] = "Create Test";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-journal-plus text-success me-2"></i>Create Test
    </h4>
    <a asp-page="/Provider/Tests/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Tests
    </a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Form.Title" class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                        <input asp-for="Form.Title" class="form-control"
                               placeholder="e.g. SSC CGL Tier 1 Full Mock Test 1" />
                        <span asp-validation-for="Form.Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Form.ExamTypeId" class="form-label fw-medium">Exam Type <span class="text-danger">*</span></label>
                        <select asp-for="Form.ExamTypeId" class="form-select">
                            <option value="0">-- Select Exam Type --</option>
                            @foreach (var et in Model.ExamTypes)
                            {
                                <option value="@et.Id">@et.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Form.ExamTypeId" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Form.DurationMinutes" class="form-label fw-medium">Duration (minutes)</label>
                            <input asp-for="Form.DurationMinutes" class="form-control" type="number" min="1" max="360" />
                            <span asp-validation-for="Form.DurationMinutes" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Form.PassingPercent" class="form-label fw-medium">Passing %</label>
                            <div class="input-group">
                                <input asp-for="Form.PassingPercent" class="form-control" type="number" min="0" max="100" step="0.5" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="Form.PassingPercent" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="Form.NegativeMarkingEnabled" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="Form.NegativeMarkingEnabled" class="form-check-label">
                                Enable Negative Marking
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-plus-circle me-2"></i>Create &amp; Open Editor
                        </button>
                        <a asp-page="/Provider/Tests/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="alert alert-info border-0 shadow-sm">
            <i class="bi bi-lightbulb me-2"></i>
            <strong>After creating</strong>, you'll be taken to the test editor where you can:
            <ul class="mb-0 mt-2 small ps-3">
                <li>Add sections (e.g. Quantitative, Reasoning)</li>
                <li>Configure question pools per section</li>
                <li>Publish the test when ready</li>
                <li>Then add it to a test series</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
