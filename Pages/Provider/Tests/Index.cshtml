@page
@model GridAcademy.Pages.Provider.Tests.IndexModel
@using GridAcademy.Data.Entities.Assessment
@{
    ViewData["Title"] = "My Tests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-journal-check text-success me-2"></i>My Tests
    </h4>
    <a asp-page="/Provider/Tests/Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-2"></i>Create Test
    </a>
</div>

<div class="alert alert-light border mb-3 small">
    <i class="bi bi-info-circle me-2 text-primary"></i>
    Tests are the individual mock exams. Add tests to a series to publish them on the marketplace.
</div>

@if (!Model.Tests.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-journal-check fs-1 text-muted opacity-50 d-block mb-3"></i>
            <h5 class="text-muted">No tests yet</h5>
            <p class="text-muted mb-3">Create your first test to get started.</p>
            <a asp-page="/Provider/Tests/Create" class="btn btn-success">
                <i class="bi bi-plus-circle me-2"></i>Create Test
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Exam Type</th>
                        <th class="text-center">Duration</th>
                        <th class="text-center">Sections</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Tests)
                    {
                        <tr>
                            <td class="fw-medium">@t.Title</td>
                            <td>
                                <span class="badge bg-light text-dark border">@t.ExamTypeName</span>
                            </td>
                            <td class="text-center">@t.DurationMinutes min</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@t.SectionCount</span>
                            </td>
                            <td>
                                @{
                                    var statusBadge = t.Status switch
                                    {
                                        TestStatus.Published => "success",
                                        TestStatus.Archived  => "secondary",
                                        _                    => "warning text-dark"
                                    };
                                }
                                <span class="badge bg-@statusBadge">@t.Status</span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/Admin/Content/Tests/Edit?id=@t.Id" class="btn btn-sm btn-outline-primary" title="Edit in Test Editor">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (t.Status == TestStatus.Draft)
                                    {
                                        <form method="post" asp-page-handler="Delete" class="d-inline"
                                              onsubmit="return confirm('Delete this test? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
