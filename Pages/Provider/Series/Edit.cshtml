@page "{id:guid}"
@model GridAcademy.Pages.Provider.Series.EditModel
@using GridAcademy.Data.Entities.Marketplace
@{
    ViewData["Title"] = Model.Series is not null ? $"Edit Series: {Model.Series.Title}" : "Edit Series";
    var isPublished = Model.Series?.Status == "Published";
    var isDraft = Model.Series?.Status == "Draft";
    var isRejected = Model.Series?.Status == "Rejected";
    var canEdit = isDraft || isRejected;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">
            <i class="bi bi-pencil-square text-success me-2"></i>
            @(Model.Series?.Title ?? "Edit Series")
        </h4>
        @if (Model.Series is not null)
        {
            var statusBadge = Model.Series.Status switch
            {
                "Published"     => "success",
                "PendingReview" => "warning text-dark",
                "Rejected"      => "danger",
                _               => "secondary"
            };
            <span class="badge bg-@statusBadge mt-1">@Model.Series.Status</span>
        }
    </div>
    <div class="d-flex gap-2">
        @if (isDraft && Model.LinkedTests.Any())
        {
            <form method="post" asp-page-handler="Submit" asp-route-id="@Model.SeriesId"
                  onsubmit="return confirm('Submit this series for admin review? You will not be able to edit it while under review.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-send me-2"></i>Submit for Review
                </button>
            </form>
        }
        <a asp-page="/Provider/Series/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

@if (isPublished)
{
    <div class="alert alert-warning mb-3">
        <i class="bi bi-lock me-2"></i>
        <strong>This series is published.</strong> You cannot edit it while it is live.
        Contact support if you need to make changes.
    </div>
}

<div class="row">
    <!-- Left: Series Form -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-info-circle me-2"></i>Series Details
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save" asp-route-id="@Model.SeriesId">
                    @Html.AntiForgeryToken()

                    <fieldset @(isPublished ? "disabled" : "")>
                        <div class="mb-3">
                            <label asp-for="Form.Title" class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                            <input asp-for="Form.Title" class="form-control" />
                            <span asp-validation-for="Form.Title" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.ExamTypeId" class="form-label fw-medium">Exam Type <span class="text-danger">*</span></label>
                                <select asp-for="Form.ExamTypeId" class="form-select">
                                    <option value="0">-- Select Exam Type --</option>
                                    @foreach (var et in Model.ExamTypes)
                                    {
                                        <option value="@et.Id">@et.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="Form.ExamTypeId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.SeriesType" class="form-label fw-medium">Series Type</label>
                                <select asp-for="Form.SeriesType" class="form-select">
                                    <option value="@((int)SeriesType.FullMock)">Full Mock</option>
                                    <option value="@((int)SeriesType.Sectional)">Sectional</option>
                                    <option value="@((int)SeriesType.PreviousYear)">Previous Year</option>
                                    <option value="@((int)SeriesType.MiniMock)">Mini Mock</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.PriceInr" class="form-label fw-medium">Price (INR)</label>
                                <div class="input-group">
                                    <span class="input-group-text">&#8377;</span>
                                    <input asp-for="Form.PriceInr" class="form-control" type="number" min="0" step="0.01" />
                                </div>
                                <div class="form-text">Set 0 for free.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.Language" class="form-label fw-medium">Language</label>
                                <select asp-for="Form.Language" class="form-select">
                                    <option value="English">English</option>
                                    <option value="Hindi">Hindi</option>
                                    <option value="Bilingual">Bilingual</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="Form.IsFirstTestFree" class="form-check-input" type="checkbox" />
                                <label asp-for="Form.IsFirstTestFree" class="form-check-label">
                                    Is First Test Free
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.ShortDescription" class="form-label fw-medium">Short Description</label>
                            <textarea asp-for="Form.ShortDescription" class="form-control" rows="2" maxlength="500"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.FullDescription" class="form-label fw-medium">Full Description</label>
                            <textarea asp-for="Form.FullDescription" class="form-control" rows="5"></textarea>
                            <div class="form-text">Supports rich text HTML.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Form.ThumbnailUrl" class="form-label fw-medium">Thumbnail URL</label>
                            <input asp-for="Form.ThumbnailUrl" class="form-control" />
                        </div>

                        @if (!isPublished)
                        {
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-floppy me-2"></i>Save Changes
                            </button>
                        }
                    </fieldset>
                </form>
            </div>
        </div>
    </div>

    <!-- Right: Tests Panel -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent border-bottom fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-journal-check me-2"></i>Tests in this Series</span>
                <span class="badge bg-secondary">@Model.LinkedTests.Count</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.LinkedTests.Any())
                {
                    <div class="p-3 text-center text-muted small">
                        No tests added yet.
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in Model.LinkedTests)
                        {
                            <li class="list-group-item py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-medium small">@t.Title</div>
                                        <div class="text-muted" style="font-size:.75rem">
                                            @t.DurationMinutes min &bull; Order: @t.SortOrder
                                            @if (t.IsFreePreview)
                                            {
                                                <span class="badge bg-success ms-1" style="font-size:.65rem">Free Preview</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!isPublished)
                                    {
                                        <form method="post" asp-page-handler="RemoveTest" asp-route-id="@Model.SeriesId"
                                              class="ms-2"
                                              onsubmit="return confirm('Remove this test from the series?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="testId" value="@t.TestId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Remove">
                                                <i class="bi bi-x-lg" style="font-size:.7rem"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        @if (!isPublished)
        {
            <!-- Add Test Form -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent border-bottom fw-semibold small">
                    <i class="bi bi-plus-circle me-2 text-success"></i>Add Test to Series
                </div>
                <div class="card-body">
                    @if (!Model.AvailableTests.Any())
                    {
                        <div class="text-muted small text-center py-2">
                            No published tests available.
                            <a asp-page="/Provider/Tests/Create" class="d-block mt-1">Create a Test first</a>
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="AddTest" asp-route-id="@Model.SeriesId">
                            @Html.AntiForgeryToken()
                            <div class="mb-2">
                                <label class="form-label small fw-medium">Select Test</label>
                                <select name="testId" class="form-select form-select-sm" required>
                                    <option value="">-- Select --</option>
                                    @foreach (var t in Model.AvailableTests)
                                    {
                                        <option value="@t.Id">@t.Title (@t.Duration min)</option>
                                    }
                                </select>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label class="form-label small fw-medium">Sort Order</label>
                                    <input name="sortOrder" type="number" class="form-control form-control-sm"
                                           value="@(Model.LinkedTests.Count + 1)" min="1" />
                                </div>
                                <div class="col-6 d-flex align-items-end">
                                    <div class="form-check pb-1">
                                        <input name="isFreePreview" type="checkbox" class="form-check-input"
                                               value="true" id="freePreviewCheck" />
                                        <label class="form-check-label small" for="freePreviewCheck">Free Preview</label>
                                    </div>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                <i class="bi bi-plus me-1"></i>Add Test
                            </button>
                        </form>
                    }
                </div>
            </div>
        }

        @if (isDraft && Model.LinkedTests.Any())
        {
            <div class="alert alert-success border-0 shadow-sm small">
                <i class="bi bi-check-circle me-2"></i>
                Your series has @Model.LinkedTests.Count test(s). Ready to submit for review!
            </div>
        }
        else if (isDraft && !Model.LinkedTests.Any())
        {
            <div class="alert alert-warning border-0 shadow-sm small">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Add at least one test before submitting for review.
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
