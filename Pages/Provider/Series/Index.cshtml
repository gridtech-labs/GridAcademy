@page
@model GridAcademy.Pages.Provider.Series.IndexModel
@{
    ViewData["Title"] = "My Test Series";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">
        <i class="bi bi-collection-play text-success me-2"></i>My Test Series
    </h4>
    <a asp-page="/Provider/Series/Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-2"></i>Create New Series
    </a>
</div>

<!-- Filter tabs -->
<ul class="nav nav-tabs mb-3" id="seriesFilterTabs">
    <li class="nav-item">
        <a class="nav-link active" href="#" data-filter="all">All (@Model.Series.TotalCount)</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" data-filter="Draft">Draft</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" data-filter="PendingReview">Pending Review</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" data-filter="Published">Published</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#" data-filter="Rejected">Rejected</a>
    </li>
</ul>

@if (!Model.Series.Items.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-collection-play fs-1 text-muted opacity-50 d-block mb-3"></i>
            <h5 class="text-muted">No series yet</h5>
            <p class="text-muted mb-3">Create your first test series to get started.</p>
            <a asp-page="/Provider/Series/Create" class="btn btn-success">
                <i class="bi bi-plus-circle me-2"></i>Create Test Series
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="seriesTable">
                <thead class="table-light">
                    <tr>
                        <th>Series</th>
                        <th>Status</th>
                        <th class="text-center">Tests</th>
                        <th class="text-center">Sales</th>
                        <th class="text-center">Rating</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Series.Items)
                    {
                        <tr data-status="@s.Status">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(s.ThumbnailUrl))
                                    {
                                        <img src="@s.ThumbnailUrl" alt="thumbnail" class="rounded"
                                             style="width:48px;height:36px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-success bg-opacity-10 rounded d-flex align-items-center justify-content-center"
                                             style="width:48px;height:36px;">
                                            <i class="bi bi-collection-play text-success"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-medium">@s.Title</div>
                                        <div class="d-flex gap-1 mt-1 flex-wrap">
                                            <span class="badge bg-light text-dark border" style="font-size:.7rem">@s.ExamTypeName</span>
                                            <span class="badge bg-light text-dark border" style="font-size:.7rem">@s.SeriesType</span>
                                            @if (s.Language != "English")
                                            {
                                                <span class="badge bg-info text-dark" style="font-size:.7rem">@s.Language</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusBadge = s.Status switch
                                    {
                                        "Published"     => "success",
                                        "PendingReview" => "warning text-dark",
                                        "Rejected"      => "danger",
                                        _               => "secondary"
                                    };
                                }
                                <span class="badge bg-@statusBadge">@s.Status</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@s.TestCount</span>
                            </td>
                            <td class="text-center">@s.PurchaseCount</td>
                            <td class="text-center">
                                @if (s.ReviewCount > 0)
                                {
                                    <span><i class="bi bi-star-fill text-warning small"></i> @s.AvgRating.ToString("N1")</span>
                                    <span class="text-muted small">(@s.ReviewCount)</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end fw-medium">
                                @if (s.PriceInr == 0)
                                {
                                    <span class="badge bg-success">Free</span>
                                }
                                else
                                {
                                    <span>&#8377;@s.PriceInr.ToString("N2")</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    @if (s.Status == "Draft" || s.Status == "Rejected")
                                    {
                                        <a asp-page="/Provider/Series/Edit" asp-route-id="@s.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Provider/Series/Edit" asp-route-id="@s.Id"
                                           class="btn btn-sm btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    }

                                    @if (s.Status == "Draft")
                                    {
                                        <form method="post" asp-page-handler="Submit" class="d-inline"
                                              onsubmit="return confirm('Submit this series for admin review?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Submit for Review">
                                                <i class="bi bi-send"></i>
                                            </button>
                                        </form>

                                        <form method="post" asp-page-handler="Delete" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this series? This cannot be undone.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.Series.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int p = 1; p <= Model.Series.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-page="/Provider/Series/Index" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
<script>
    // Client-side filter tabs
    document.querySelectorAll('#seriesFilterTabs .nav-link').forEach(tab => {
        tab.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('#seriesFilterTabs .nav-link').forEach(t => t.classList.remove('active'));
            this.classList.add('active');

            const filter = this.dataset.filter;
            document.querySelectorAll('#seriesTable tbody tr').forEach(row => {
                row.style.display = (filter === 'all' || row.dataset.status === filter) ? '' : 'none';
            });
        });
    });
</script>
}
