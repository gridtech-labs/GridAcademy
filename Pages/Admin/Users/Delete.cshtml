@page "{id:guid}"
@model GridAcademy.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="fw-bold mb-0 text-danger">Delete User</h5>
</div>

@if (Model.UserInfo is not null)
{
    <div class="row">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger bg-opacity-10 border-danger">
                    <h6 class="fw-semibold text-danger mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion
                    </h6>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted mb-3">
                        You are about to permanently delete the following user. This action <strong>cannot be undone</strong>.
                    </p>

                    <table class="table table-sm table-borderless mb-4">
                        <tr>
                            <th class="text-muted w-25">Name</th>
                            <td class="fw-semibold">@Model.UserInfo.FullName</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Email</th>
                            <td>@Model.UserInfo.Email</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Role</th>
                            <td>
                                @{
                                    var roleClass = Model.UserInfo.Role switch
                                    {
                                        "Admin"      => "badge-admin",
                                        "Instructor" => "badge-instructor",
                                        _            => "badge-user"
                                    };
                                }
                                <span class="badge @roleClass">@Model.UserInfo.Role</span>
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Status</th>
                            <td>
                                @if (Model.UserInfo.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Inactive</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Joined</th>
                            <td class="text-muted">@Model.UserInfo.CreatedAt.ToString("MMMM d, yyyy")</td>
                        </tr>
                    </table>

                    <form method="post">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
