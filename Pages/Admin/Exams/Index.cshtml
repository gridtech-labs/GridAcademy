@page
@model GridAcademy.Pages.Admin.Exams.IndexModel
@using GridAcademy.Data.Entities.Exam
@{ ViewData["Title"] = "Exams"; }

<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <h4 class="mb-0 fw-bold"><i class="bi bi-mortarboard me-2 text-primary"></i>Exams</h4>
    <a asp-page="Edit" class="btn btn-primary btn-sm ms-auto">
        <i class="bi bi-plus-lg me-1"></i>New Exam
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2">
        <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="Search" value="@Model.Search" class="form-control form-control-sm"
               placeholder="Search exams..." />
    </div>
    <div class="col-md-3">
        <select name="LevelId" class="form-select form-select-sm">
            <option value="">— All Levels —</option>
            @foreach (var l in Model.Levels)
            {
                <option value="@l.Id" selected="@(Model.LevelId == l.Id)">@l.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-search me-1"></i>Filter
        </button>
        <a asp-page="Index" class="btn btn-sm btn-link text-muted">Clear</a>
    </div>
</form>

<div class="card shadow-sm">
    <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Exam</th>
                <th>Level</th>
                <th>Conducting Body</th>
                <th class="text-center">Tests</th>
                <th class="text-center">Status</th>
                <th class="text-center">Featured</th>
                <th class="text-end pe-3">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Exams)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@e.Title</div>
                        <small class="text-muted">/exams/@e.Slug</small>
                    </td>
                    <td>
                        @if (e.ExamLevelName != null)
                        { <span class="badge bg-info text-dark">@e.ExamLevelName</span> }
                    </td>
                    <td class="text-muted small">@e.ConductingBody</td>
                    <td class="text-center"><span class="badge bg-secondary">@e.TestCount</span></td>
                    <td class="text-center">
                        @if (e.Status == ExamPageStatus.Published)
                        { <span class="badge bg-success">Published</span> }
                        else
                        { <span class="badge bg-warning text-dark">Draft</span> }
                    </td>
                    <td class="text-center">
                        @if (e.IsFeatured) { <i class="bi bi-star-fill text-warning"></i> }
                    </td>
                    <td class="text-end pe-3">
                        <a asp-page="Tests" asp-route-id="@e.Id" class="btn btn-xs btn-outline-success me-1" title="Tests">
                            <i class="bi bi-journal-check"></i> Tests
                        </a>
                        <a asp-page="Edit" asp-route-id="@e.Id" class="btn btn-xs btn-outline-primary me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@e.Id" class="d-inline"
                              onsubmit="return confirm('Delete this exam?')">
                            <button type="submit" class="btn btn-xs btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Exams.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-mortarboard fs-2 d-block mb-2"></i>
                        No exams yet. <a asp-page="Edit">Create your first exam.</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<style>.btn-xs { padding:.1rem .4rem; font-size:.75rem; }</style>
