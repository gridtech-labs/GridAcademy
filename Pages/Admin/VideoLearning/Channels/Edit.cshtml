@page
@model EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Sales Channel" : "Add Sales Channel";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="card shadow-sm" style="max-width:560px;">
    <div class="card-body">
        @if (!Model.IsEdit)
        {
            <div class="alert alert-info small">
                <i class="bi bi-info-circle me-1"></i>
                An API key will be generated when you create the channel. It is shown only once.
            </div>
        }
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ChannelId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Channel Name <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required maxlength="200" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Base URL</label>
                <input asp-for="BaseUrl" class="form-control" type="url" placeholder="https://partner.example.com" />
                <div class="form-text">Optional. Used to identify incoming traffic.</div>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                    <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Update" : "Create")
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
