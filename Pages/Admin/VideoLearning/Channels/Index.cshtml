@page
@model IndexModel
@{
    ViewData["Title"] = "Sales Channels";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-share me-2 text-primary"></i>Sales Channels</h4>
    <a asp-page="Edit" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Channel
    </a>
</div>

@if (TempData["NewApiKey"] is string apiKey)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-key-fill me-2"></i>
        <strong>API Key (shown once):</strong>
        <code class="ms-2">@apiKey</code>
        <p class="mb-0 mt-1 small">Copy this key now — it will not be shown again.</p>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Base URL</th>
                    <th class="text-center">Created</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ch in Model.Channels)
                {
                    <tr>
                        <td class="fw-semibold">@ch.Name</td>
                        <td class="text-muted small">@(ch.BaseUrl ?? "—")</td>
                        <td class="text-center text-muted small">@ch.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <span class="badge @(ch.IsActive ? "bg-success" : "bg-secondary")">@(ch.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td class="text-center">
                            <a asp-page="Edit" asp-route-id="@ch.Id" class="btn btn-outline-primary btn-sm" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@ch.Id" class="d-inline"
                                  onsubmit="return confirm('Delete channel \'@ch.Name\'?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Channels.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No sales channels found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
