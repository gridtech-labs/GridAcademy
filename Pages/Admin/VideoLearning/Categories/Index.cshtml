@page
@model IndexModel
@{
    ViewData["Title"] = "Video Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-folder me-2 text-primary"></i>Video Categories</h4>
    <a asp-page="Edit" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Category
    </a>
</div>

<!-- Domain filter -->
<div class="mb-3">
    <form method="get" class="d-flex gap-2 align-items-center">
        <label class="form-label mb-0 fw-semibold">Filter by Domain:</label>
        <select name="domainId" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
            <option value="">All Domains</option>
            @foreach (var d in Model.Domains)
            {
                <option value="@d.Id" selected="@(Model.DomainId == d.Id)">@d.Name</option>
            }
        </select>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Domain</th>
                    <th class="text-center">Videos</th>
                    <th class="text-center">Sort</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Categories)
                {
                    <tr>
                        <td class="fw-semibold">@c.Name</td>
                        <td><span class="badge bg-light text-dark border">@c.DomainName</span></td>
                        <td class="text-center"><span class="badge bg-info text-dark">@c.VideoCount</span></td>
                        <td class="text-center">@c.SortOrder</td>
                        <td class="text-center">
                            <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span>
                        </td>
                        <td class="text-center">
                            <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id" class="d-inline"
                                  onsubmit="return confirm('Delete category \'@c.Name\'?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Categories.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No categories found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
