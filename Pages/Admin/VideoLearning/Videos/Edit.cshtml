@page
@model EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Video" : "Add Video";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="card shadow-sm" style="max-width:700px;">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="VideoId" />

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Domain <span class="text-danger">*</span></label>
                    <select asp-for="DomainId" class="form-select" required id="domainSelect">
                        <option value="">-- Select Domain --</option>
                        @foreach (var d in Model.Domains)
                        {
                            <option value="@d.Id">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" class="form-select" required id="categorySelect">
                        <option value="">-- Select Category --</option>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.Id" data-domain="@c.DomainId">@c.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control" required maxlength="300" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Video File</label>
                @if (Model.IsEdit && !string.IsNullOrEmpty(Model.FilePath))
                {
                    <div class="mb-2 text-muted small">Current: @Model.OriginalFileName (@Model.FileSizeMb MB)</div>
                }
                <input type="file" name="VideoFile" accept="video/*" class="form-control" @(!Model.IsEdit ? "required" : "") />
                <div class="form-text">Supported: MP4, WebM, MOV. Max 2 GB.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Thumbnail</label>
                @if (!string.IsNullOrEmpty(Model.ThumbnailPath))
                {
                    <div class="mb-2">
                        <img src="@Model.ThumbnailPath" class="rounded border" style="height:64px;object-fit:cover;" />
                    </div>
                }
                <input type="file" name="ThumbnailFile" accept="image/*" class="form-control" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-4">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select">
                        @foreach (VideoStatus s in Enum.GetValues<VideoStatus>())
                        {
                            <option value="@((int)s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-sm-4 d-flex align-items-end pb-1">
                    <div class="form-check form-switch">
                        <input asp-for="IsFreePreview" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsFreePreview" class="form-check-label fw-semibold">Free Preview</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Update" : "Create")
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    // Filter categories by selected domain
    const domainSel = document.getElementById('domainSelect');
    const catSel = document.getElementById('categorySelect');
    function filterCategories() {
        const domId = domainSel.value;
        Array.from(catSel.options).forEach(o => {
            if (!o.value) return;
            o.hidden = domId && o.dataset.domain !== domId;
        });
    }
    domainSel.addEventListener('change', filterCategories);
    filterCategories();
</script>
}
