@page
@model EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Coupon" : "Add Coupon";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="card shadow-sm" style="max-width:640px;">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CouponId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Coupon Code <span class="text-danger">*</span></label>
                @if (Model.IsEdit)
                {
                    <input asp-for="Code" class="form-control text-uppercase font-monospace" required maxlength="50" readonly />
                }
                else
                {
                    <input asp-for="Code" class="form-control text-uppercase font-monospace" required maxlength="50" />
                }
                <div class="form-text">Alphanumeric, no spaces. e.g. SAVE20</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <input asp-for="Description" class="form-control" maxlength="300" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Discount Type <span class="text-danger">*</span></label>
                    <select asp-for="DiscountType" class="form-select" required>
                        @foreach (DiscountType dt in Enum.GetValues<DiscountType>())
                        {
                            <option value="@((int)dt)">@dt</option>
                        }
                    </select>
                </div>
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Discount Value <span class="text-danger">*</span></label>
                    <input asp-for="DiscountValue" type="number" step="0.01" min="0" class="form-control" required />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Max Discount INR</label>
                    <input asp-for="MaxDiscountInr" type="number" step="0.01" min="0" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Max Discount USD</label>
                    <input asp-for="MaxDiscountUsd" type="number" step="0.01" min="0" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Valid From</label>
                    <input asp-for="ValidFrom" type="date" class="form-control" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Valid To</label>
                    <input asp-for="ValidTo" type="date" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Usage Limit</label>
                    <input asp-for="UsageLimit" type="number" min="1" class="form-control" placeholder="Unlimited if blank" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Restrict to Program</label>
                    <select asp-for="ProgramId" class="form-select">
                        <option value="">All Programs</option>
                        @foreach (var p in Model.Programs)
                        {
                            <option value="@p.Id">@p.Title</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                    <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Update" : "Create")
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
