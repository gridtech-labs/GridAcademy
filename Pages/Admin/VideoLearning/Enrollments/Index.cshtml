@page
@model IndexModel
@{
    ViewData["Title"] = "Enrollments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-person-check me-2 text-primary"></i>Enrollments</h4>
    <a asp-page="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Enroll User
    </a>
</div>

<!-- Filters -->
<div class="mb-3">
    <form method="get" class="row g-2 align-items-center">
        <div class="col">
            <input type="email" name="userEmail" value="@Model.FilterRequest.UserEmail" class="form-control form-control-sm" placeholder="Filter by email…" />
        </div>
        <div class="col-auto">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (EnrollmentStatus s in Enum.GetValues<EnrollmentStatus>())
                {
                    <option value="@((int)s)" selected="@(Model.FilterRequest.Status == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <input type="date" name="fromDate" value="@Model.FilterRequest.FromDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-auto">
            <input type="date" name="toDate" value="@Model.FilterRequest.ToDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-auto">
            <button class="btn btn-sm btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Filter</button>
        </div>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>User</th>
                    <th>Program</th>
                    <th>Plan</th>
                    <th class="text-center">Paid (INR)</th>
                    <th class="text-center">Enrolled</th>
                    <th class="text-center">Expires</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Enrollments.Items)
                {
                    <tr>
                        <td class="small">@e.UserEmail</td>
                        <td class="fw-semibold small">@e.ProgramTitle</td>
                        <td class="text-muted small">@e.PlanName</td>
                        <td class="text-center">₹@e.AmountPaidInr</td>
                        <td class="text-center text-muted small">@e.EnrolledAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center text-muted small">@(e.ExpiresAt.HasValue ? e.ExpiresAt.Value.ToString("dd MMM yyyy") : "Lifetime")</td>
                        <td class="text-center">
                            @{
                                var (ebg, elbl) = e.Status switch
                                {
                                    EnrollmentStatus.Active    => ("bg-success", "Active"),
                                    EnrollmentStatus.Expired   => ("bg-warning text-dark", "Expired"),
                                    EnrollmentStatus.Cancelled => ("bg-danger", "Cancelled"),
                                    _                          => ("bg-secondary", e.Status.ToString())
                                };
                            }
                            <span class="badge @ebg">@elbl</span>
                        </td>
                        <td class="text-center">
                            @if (e.Status == EnrollmentStatus.Active)
                            {
                                <form method="post" asp-page-handler="Cancel" asp-route-id="@e.Id" class="d-inline"
                                      onsubmit="return confirm('Cancel enrollment for \'@e.UserEmail\'?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-danger btn-sm" title="Cancel"><i class="bi bi-x-circle"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Enrollments.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No enrollments found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Enrollments.TotalCount > Model.Enrollments.PageSize)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Enrollments.Items.Count of @Model.Enrollments.TotalCount</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= (int)Math.Ceiling((double)Model.Enrollments.TotalCount / Model.Enrollments.PageSize); i++)
                    {
                        <li class="page-item @(i == Model.FilterRequest.Page ? "active" : "")">
                            <a class="page-link" asp-page="Index" asp-route-page="@i"
                               asp-route-userEmail="@Model.FilterRequest.UserEmail"
                               asp-route-status="@Model.FilterRequest.Status"
                               asp-route-fromDate="@Model.FilterRequest.FromDate?.ToString("yyyy-MM-dd")"
                               asp-route-toDate="@Model.FilterRequest.ToDate?.ToString("yyyy-MM-dd")">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
