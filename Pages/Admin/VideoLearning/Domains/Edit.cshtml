@page
@model EditModel
@{
    ViewData["Title"] = Model.IsEdit ? "Edit Domain" : "Add Domain";
}

<div class="d-flex align-items-center mb-4 gap-2">
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="card shadow-sm" style="max-width:640px;">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Domain Name <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required maxlength="200" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Logo Image</label>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.LogoUrl" class="rounded border" style="height:64px;object-fit:contain;" />
                    </div>
                }
                <input type="file" name="LogoFile" accept="image/*" class="form-control" />
                <div class="form-text">Recommended: square image, 200×200px</div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                </div>
                <div class="col-sm-6 d-flex align-items-end pb-1">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> @(Model.IsEdit ? "Update" : "Create")
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
