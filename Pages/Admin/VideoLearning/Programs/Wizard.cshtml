@page
@model WizardModel
@{
    ViewData["Title"] = Model.IsEdit ? $"Edit Program: {Model.ProgramTitle}" : "Create Program";
    var step = Model.CurrentStep;
}

<style>
.wizard-steps { display:flex; align-items:center; gap:0; margin-bottom:2rem; }
.wizard-step { display:flex; align-items:center; cursor:pointer; }
.step-num {
    width:36px; height:36px; border-radius:50%; border:2px solid #dee2e6;
    display:inline-flex; align-items:center; justify-content:center;
    font-weight:700; font-size:.85rem; background:#fff; color:#6c757d;
    transition:all .2s;
}
.wizard-step.active .step-num  { background:#dc3545; border-color:#dc3545; color:#fff; }
.wizard-step.done   .step-num  { background:#198754; border-color:#198754; color:#fff; }
.step-label { margin-left:.5rem; font-weight:500; color:#6c757d; }
.wizard-step.active .step-label, .wizard-step.done .step-label { color:#212529; }
.wizard-arrow { margin:0 .75rem; color:#dee2e6; font-size:1.2rem; }
.node-tree { border-collapse:collapse; width:100%; }
.node-tree td, .node-tree th { padding:.5rem .75rem; border:1px solid #dee2e6; vertical-align:middle; }
.node-tree th { background:#dc3545; color:#fff; font-weight:600; }
.node-tree tr.root-row td { background:#f8f9fa; font-weight:700; }
.node-tree tr.module-row td { background:#fff; padding-left:2rem; }
.node-tree tr.item-row td { padding-left:3.5rem; }
.launch-status-active  { color:#198754; }
.launch-status-blocked { color:#dc3545; }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-3">
    <div class="d-flex align-items-center gap-3">
        <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
        <h4 class="mb-0">@ViewData["Title"]</h4>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Index" class="btn btn-outline-secondary btn-sm">Manage Program</a>
        <a asp-page="Wizard" class="btn btn-outline-primary btn-sm">Add Program</a>
    </div>
</div>

<!-- Wizard Steps Bar -->
<div class="wizard-steps mb-4">
    @{
        string StepClass(int s) => s == step ? "wizard-step active" : (s < step ? "wizard-step done" : "wizard-step");
        string StepIcon(int s)  => s < step ? "<i class='bi bi-check-lg'></i>" : s.ToString();
    }
    <a href="?id=@Model.Id&step=1" class="text-decoration-none @StepClass(1)">
        <span class="step-num">@Html.Raw(StepIcon(1))</span>
        <span class="step-label">Basic Information</span>
    </a>
    <span class="wizard-arrow">&#8594;</span>
    <a href="?id=@Model.Id&step=2" class="text-decoration-none @(Model.IsEdit ? StepClass(2) : "wizard-step text-muted pe-none")">
        <span class="step-num">@Html.Raw(StepIcon(2))</span>
        <span class="step-label">Add Learning</span>
    </a>
    <span class="wizard-arrow">&#8594;</span>
    <a href="?id=@Model.Id&step=3" class="text-decoration-none @(Model.IsEdit ? StepClass(3) : "wizard-step text-muted pe-none")">
        <span class="step-num">@Html.Raw(StepIcon(3))</span>
        <span class="step-label">Publish As Course</span>
    </a>
</div>

<!-- STEP 1: Basic Information -->
@if (step == 1)
{
    <div class="card shadow-sm" style="max-width:720px;">
        <div class="card-body">
            <form method="post" asp-page-handler="SaveBasic" id="basicForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Program Name <span class="text-danger">*</span></label>
                        <input asp-for="ProgramTitle" class="form-control" required maxlength="300" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Learning Code</label>
                        <input asp-for="LearningCode" class="form-control" maxlength="50" placeholder="e.g. PROG-001" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Domain <span class="text-danger">*</span></label>
                    <select asp-for="DomainId" class="form-select" required>
                        <option value="">-- Select Domain --</option>
                        @foreach (var d in Model.Domains)
                        {
                            <option value="@d.Id">@d.Name</option>
                        }
                    </select>
                    <div class="form-text">Domain determines the target audience (e.g. Insurance, Health Care, Academy)</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Short Description</label>
                    <input asp-for="ShortDescription" class="form-control" maxlength="500" placeholder="One-line summary shown on cards" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Full Description</label>
                    <div id="descEditor" style="min-height:160px; border:1px solid #dee2e6; border-radius:4px; padding:.5rem;"></div>
                    <input type="hidden" asp-for="Description" id="descHidden" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsBlendedLearning" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsBlendedLearning" class="form-check-label fw-semibold">Blended Learning</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger px-4">
                        Next: Add Learning <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<!-- STEP 2: Add Learning -->
@if (step == 2 && Model.IsEdit)
{
    <div class="mb-3">
        <strong>Program Name</strong> &nbsp; @Model.ProgramTitle
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="node-tree">
                <thead>
                    <tr>
                        <th style="width:35%">Node Name</th>
                        <th style="width:15%">Type</th>
                        <th style="width:20%">Resource Status</th>
                        <th>Options</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Program root row -->
                    <tr class="root-row">
                        <td><i class="bi bi-folder-fill text-warning me-2"></i>@Model.ProgramTitle</td>
                        <td></td>
                        <td></td>
                        <td>
                            <button class="btn btn-link btn-sm p-0 me-2" data-bs-toggle="modal" data-bs-target="#addLpModal">
                                + Add Learning Path
                            </button>
                        </td>
                    </tr>

                    @foreach (var lp in Model.AssignedPaths)
                    {
                        <tr class="module-row">
                            <td><i class="bi bi-journals text-primary me-2"></i>@lp.Title</td>
                            <td><span class="badge bg-primary">Learning Path</span></td>
                            <td>
                                @if (lp.IsActive)
                                {
                                    <span class="text-success small">Active &middot; @lp.NodeCount nodes / @lp.ModuleCount modules</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-page="/Admin/VideoLearning/LearningPaths/Builder" asp-route-id="@lp.Id"
                                   class="btn btn-link btn-sm p-0 me-2" target="_blank">Edit Path</a>
                                <form method="post" asp-page-handler="RemoveLp" asp-route-lpId="@lp.Id" class="d-inline"
                                      onsubmit="return confirm('Remove this learning path from program?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-link btn-sm p-0 text-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                        @* Content nodes are managed via the Learning Path Builder *@
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Learning Path modal -->
    <div class="modal fade" id="addLpModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Learning Path</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="AddLp">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        @if (!Model.AvailablePaths.Any())
                        {
                            <p class="text-muted">All learning paths are already assigned, or none exist.
                                <a asp-page="/Admin/VideoLearning/LearningPaths/Builder" target="_blank">Create a learning path</a>.
                            </p>
                        }
                        else
                        {
                            <label class="form-label fw-semibold">Select Learning Path</label>
                            <select name="LpId" class="form-select" required>
                                <option value="">-- Select --</option>
                                @foreach (var lp in Model.AvailablePaths)
                                {
                                    <option value="@lp.Id">@lp.Title (@lp.DomainName)</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        @if (Model.AvailablePaths.Any())
                        {
                            <button type="submit" class="btn btn-primary">Add</button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="?id=@Model.Id&step=3" class="btn btn-danger px-4">
            Next: Publish As Course <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
}

<!-- STEP 3: Publish As Course -->
@if (step == 3 && Model.IsEdit)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 text-muted">Course Launch</h6>
        <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#addLaunchModal">
            <i class="bi bi-plus-lg me-1"></i>Add New Launch
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><input type="checkbox" /></th>
                        <th>Course Launch</th>
                        <th>Status</th>
                        <th>Blocked Reason</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var launch in Model.CourseLaunches)
                    {
                        <tr>
                            <td><input type="checkbox" /></td>
                            <td class="fw-semibold">@launch.Name</td>
                            <td>
                                <span class="launch-status-@launch.Status.ToString().ToLower()">
                                    @launch.Status
                                </span>
                            </td>
                            <td class="text-muted small">@launch.BlockedReason</td>
                            <td class="text-muted small">@(launch.StartDate?.ToString("MMM d, yyyy") ?? "NA")</td>
                            <td class="text-muted small">@(launch.EndDate?.ToString("MMM d, yyyy") ?? "NA")</td>
                            <td>
                                <button class="btn btn-link btn-sm p-0 me-1 text-primary"
                                        onclick="editLaunch(@launch.Id, '@launch.Name', '@launch.Status', '@launch.BlockedReason', '@(launch.StartDate?.ToString("yyyy-MM-dd"))', '@(launch.EndDate?.ToString("yyyy-MM-dd"))', @launch.MaxEnrollments)"
                                        title="Edit"><i class="bi bi-pencil"></i></button>
                                <form method="post" asp-page-handler="DeleteLaunch" asp-route-launchId="@launch.Id"
                                      class="d-inline" onsubmit="return confirm('Delete this launch?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-link btn-sm p-0 text-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.CourseLaunches.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No launches yet. Click "Add New Launch" to create one.</td></tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.CourseLaunches.Any())
        {
            <div class="card-footer text-muted small">
                Showing 1 to @Model.CourseLaunches.Count of @Model.CourseLaunches.Count records
            </div>
        }
    </div>

    <!-- Add/Edit Launch Modal -->
    <div class="modal fade" id="addLaunchModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="launchModalTitle">Add New Launch</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="SaveLaunch">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="LaunchId" id="launchId" value="0" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Launch Name <span class="text-danger">*</span></label>
                            <input type="text" name="LaunchName" id="launchName" class="form-control" required maxlength="200"
                                   placeholder="e.g. Batch 2026-A, Q1 2026" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="LaunchStatus" id="launchStatus" class="form-select">
                                <option value="0">Active</option>
                                <option value="1">Blocked</option>
                                <option value="2">Closed</option>
                            </select>
                        </div>
                        <div class="mb-3" id="blockedReasonRow" style="display:none">
                            <label class="form-label fw-semibold">Blocked Reason</label>
                            <input type="text" name="BlockedReason" id="blockedReason" class="form-control" maxlength="500" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Start Date</label>
                                <input type="date" name="LaunchStartDate" id="launchStart" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">End Date</label>
                                <input type="date" name="LaunchEndDate" id="launchEnd" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Max Enrollments <small class="text-muted">(0 = unlimited)</small></label>
                            <input type="number" name="MaxEnrollments" id="maxEnroll" class="form-control" value="0" min="0" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Save Launch</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
@if (step == 1)
{
    <text>
    if (typeof Quill !== 'undefined') {
        var q = new Quill('#descEditor', {
            theme: 'snow',
            modules: { toolbar: [['bold','italic','underline'],['link'],[{ list:'bullet' },{ list:'ordered' }],['clean']] }
        });
        var hiddenDesc = document.getElementById('descHidden');
        if (hiddenDesc && hiddenDesc.value) q.root.innerHTML = hiddenDesc.value;
        document.getElementById('basicForm').addEventListener('submit', function() {
            hiddenDesc.value = q.root.innerHTML;
        });
    }
    </text>
}

@if (step == 3)
{
    <text>
    document.getElementById('launchStatus').addEventListener('change', function() {
        document.getElementById('blockedReasonRow').style.display = this.value === '1' ? '' : 'none';
    });

    function editLaunch(id, name, status, reason, start, end, max) {
        document.getElementById('launchModalTitle').textContent = 'Edit Launch';
        document.getElementById('launchId').value    = id;
        document.getElementById('launchName').value  = name;
        document.getElementById('launchStatus').value = {'Active':'0','Blocked':'1','Closed':'2'}[status] || '0';
        document.getElementById('blockedReason').value = reason || '';
        document.getElementById('blockedReasonRow').style.display = status === 'Blocked' ? '' : 'none';
        document.getElementById('launchStart').value = start || '';
        document.getElementById('launchEnd').value   = end   || '';
        document.getElementById('maxEnroll').value   = max   || 0;
        new bootstrap.Modal(document.getElementById('addLaunchModal')).show();
    }
    </text>
}
</script>
}
