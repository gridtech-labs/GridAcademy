@page
@model IndexModel
@{
    ViewData["Title"] = "Programs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-box-seam me-2 text-primary"></i>Programs</h4>
    <a asp-page="Wizard" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> Add Program
    </a>
</div>

<!-- Filters -->
<div class="mb-3">
    <form method="get" class="row g-2 align-items-center">
        <div class="col-auto">
            <select name="domainId" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Domains</option>
                @foreach (var d in Model.Domains)
                {
                    <option value="@d.Id" selected="@(Model.FilterRequest.DomainId == d.Id)">@d.Name</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (ProgramStatus s in Enum.GetValues<ProgramStatus>())
                {
                    <option value="@((int)s)" selected="@(Model.FilterRequest.Status == s)">@s</option>
                }
            </select>
        </div>
        <div class="col">
            <div class="input-group input-group-sm">
                <input type="text" name="search" value="@Model.FilterRequest.Search" class="form-control" placeholder="Search…" />
                <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </div>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Domain</th>
                    <th class="text-center">Paths</th>
                    <th class="text-center">Plans</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Programs.Items)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ThumbnailPath))
                            {
                                <img src="@p.ThumbnailPath" class="me-2 rounded" style="width:48px;height:32px;object-fit:cover;" />
                            }
                            <span class="fw-semibold">@p.Title</span>
                            @if (!string.IsNullOrEmpty(p.ShortDescription))
                            {
                                <div class="text-muted small">@(p.ShortDescription.Length > 60 ? p.ShortDescription[..60] + "…" : p.ShortDescription)</div>
                            }
                        </td>
                        <td><span class="badge bg-light text-dark border">@p.DomainName</span></td>
                        <td class="text-center"><span class="badge bg-info text-dark">@p.LearningPathCount</span></td>
                        <td class="text-center"><span class="badge bg-primary">@p.PricingPlanCount</span></td>
                        <td class="text-center">
                            @{
                                var (bg, lbl) = p.Status switch
                                {
                                    ProgramStatus.Published => ("bg-success", "Published"),
                                    ProgramStatus.Archived  => ("bg-warning text-dark", "Archived"),
                                    _                       => ("bg-secondary", "Draft")
                                };
                            }
                            <span class="badge @bg">@lbl</span>
                        </td>
                        <td class="text-center">
                            <a asp-page="Wizard" asp-route-id="@p.Id" asp-route-step="1" class="btn btn-outline-primary btn-sm" title="Edit">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-page="Wizard" asp-route-id="@p.Id" asp-route-step="2" class="btn btn-outline-info btn-sm" title="Add Learning">
                                <i class="bi bi-journals"></i> Learning
                            </a>
                            <a asp-page="Wizard" asp-route-id="@p.Id" asp-route-step="3" class="btn btn-outline-success btn-sm" title="Launches">
                                <i class="bi bi-rocket"></i> Launches
                            </a>
                            @if (p.Status == ProgramStatus.Draft)
                            {
                                <form method="post" asp-page-handler="Publish" asp-route-id="@p.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-success btn-sm" title="Publish"><i class="bi bi-check-circle"></i></button>
                                </form>
                            }
                            else if (p.Status == ProgramStatus.Published)
                            {
                                <form method="post" asp-page-handler="Unpublish" asp-route-id="@p.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-outline-warning btn-sm" title="Unpublish"><i class="bi bi-pause-circle"></i></button>
                                </form>
                            }
                            <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id" class="d-inline"
                                  onsubmit="return confirm('Delete program \'@p.Title\'?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm" title="Delete"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Programs.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No programs found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Programs.TotalCount > Model.Programs.PageSize)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Programs.Items.Count of @Model.Programs.TotalCount</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= (int)Math.Ceiling((double)Model.Programs.TotalCount / Model.Programs.PageSize); i++)
                    {
                        <li class="page-item @(i == Model.FilterRequest.Page ? "active" : "")">
                            <a class="page-link" asp-page="Index"
                               asp-route-page="@i"
                               asp-route-domainId="@Model.FilterRequest.DomainId"
                               asp-route-status="@Model.FilterRequest.Status"
                               asp-route-search="@Model.FilterRequest.Search">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
